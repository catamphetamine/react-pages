{
  "name": "react-pages",
  "type": "module",
  "sideEffects": [
    "*.css"
  ],
  "exports": {
    ".": {
      "import": "./lib/index.js",
      "types": "./lib/index.d.ts"
    },
    "./server-render": {
      "import": "./lib/server-render/index.js",
      "types": "./lib/server-render/index.d.ts"
    },
    "./render": {
      "import": "./lib/browser-render/index.js",
      "types": "./lib/browser-render/index.d.ts"
    }
  },
  "version": "0.9.0",
  "description": "A tiny framework for building a single-page React application",
  "dependencies": {
    "es-toolkit": "^1.47.0",
    "navigation-stack": "^0.6.12"
  },
  "devDependencies": {
    "@types/chai": "^5.2.3",
    "@types/mocha": "^10.0.10",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "chai": "^6.2.2",
    "core-js": "^3.49.0",
    "mocha": "^11.7.5",
    "npm-run-all": "^4.1.5",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "rimraf": "^6.1.3",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  },
  "peerDependencies": {
    "react": ">= 18",
    "react-dom": ">= 18"
  },
  "scripts": {
    "test": "mocha --node-option import=tsx --bail \"src/**/*.test.ts\" \"test/*.test.ts\" \"test/!(exports)/**/*.test.js\"",
    "test:exports": "mocha --bail \"test/exports/**/*.test.ts\"",
    "build:clean": "rimraf --glob ./lib/**/*",
    "build:typescript": "npx tsc",
    "build": "npm-run-all build:clean build:typescript",
    "prepublishOnly": "npm run build test test:exports"
  },
  "repository": {
    "type": "git",
    "url": "git+https://gitlab.com/catamphetamine/react-pages.git"
  },
  "keywords": [
    "react",
    "pages",
    "framework",
    "server",
    "ssr"
  ],
  "author": "catamphetamine <purecatamphetamine@gmail.com>",
  "license": "MIT",
  "bugs": {
    "url": "https://gitlab.com/catamphetamine/react-pages/issues"
  },
  "homepage": "https://gitlab.com/catamphetamine/react-pages#readme"
}
